<?xml version="1.0"?>
<!--
  Complete URDF for our bare iRobot Create3 + custom-mounted RPLIDAR + USB camera.

  This file is intended to REPLACE the system turtlebot4 robot_description
  (which assumes the standard turtlebot4 shell + sensor mounts that we don't
  have). It includes the official Create3 base model and adds our custom
  sensor mounts at their actual physical positions.

  Mounting (measured on the real robot):
    - RPLIDAR A1: 3 cm behind dock-direction center, 12 cm above base,
                  yaw = -pi/2 (triangle marker points to robot's left)
    - USB camera: 15 cm behind center on aluminum pole, 42 cm above base,
                  facing forward
    - Aluminum pole: visual only, 1 cm radius, 42 cm long
-->
<robot name="custom_tb4" xmlns:xacro="http://ros.org/wiki/xacro">

  <!-- ===== Create3 base ===== -->
  <xacro:include filename="$(find irobot_create_description)/urdf/create3.urdf.xacro" />

  <!-- ===== RPLIDAR ===== -->
  <joint name="rplidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="rplidar_link"/>
    <origin xyz="-0.03 0.0 0.12" rpy="0 0 -1.5708"/>
  </joint>

  <link name="rplidar_link">
    <visual>
      <geometry>
        <mesh filename="package://turtlebot4_description/meshes/rplidar.dae" scale="1 1 1"/>
      </geometry>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.035" length="0.04"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.17"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <!-- ===== Aluminum pole (visual only, holds the camera) ===== -->
  <joint name="pole_joint" type="fixed">
    <parent link="base_link"/>
    <child link="pole_link"/>
    <origin xyz="-0.15 0.0 0.21" rpy="0 0 0"/>
  </joint>

  <link name="pole_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.01" length="0.42"/>
      </geometry>
      <material name="silver">
        <color rgba="0.75 0.75 0.75 1.0"/>
      </material>
    </visual>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <!-- ===== USB camera ===== -->
  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <origin xyz="-0.15 0.0 0.42" rpy="0 0 0"/>
  </joint>

  <link name="camera_link">
    <visual>
      <geometry>
        <box size="0.025 0.08 0.025"/>
      </geometry>
      <material name="black">
        <color rgba="0.1 0.1 0.1 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.025 0.08 0.025"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <!-- Camera optical frame (Z forward, X right, Y down — vision convention) -->
  <joint name="camera_optical_joint" type="fixed">
    <parent link="camera_link"/>
    <child link="camera_optical_frame"/>
    <origin xyz="0 0 0" rpy="-1.5708 0 -1.5708"/>
  </joint>

  <link name="camera_optical_frame"/>

</robot>
